# vLLM with TurboQuant+ KV-cache compression for AMD ROCm.
#
# Built on the canonical ROCm 7.2 vLLM dev image. Adds
# TheTom/vllm@feature/turboquant-amd-noautotune on top so users get the TQ+ KV cache
# layouts (tq+sym, tq+asym) and the AMD-specific MFMA-friendly scoring
# kernels.
#
# Hardware: tested on MI300X (192 GB HBM3, gfx942). Should also build for
# MI250X / gfx90a but not yet validated.
#
# Build:
#   docker buildx build --platform linux/amd64 \
#     -t thetom/vllm-turboquant:rocm-7.2 -f Dockerfile.vllm-amd .
#
# Serve:
#   docker run --rm -it --device=/dev/kfd --device=/dev/dri \
#     --group-add video --ipc=host \
#     -v $HOME/.cache/huggingface:/root/.cache/huggingface \
#     -p 8000:8000 thetom/vllm-turboquant:rocm-7.2 \
#     --model Qwen/Qwen2.5-14B-Instruct-1M \
#     --kv-cache-dtype turboquant_k8v4   # K=8bit, V=4bit (62.5% savings)
#
# Verify KV savings:
#   pip install tqkit
#   tq report --model qwen2.5-14b-instruct-1m --ctx 1M --layout tq+asym
#   # → 72 GB vs 192 GB FP16 (62.5% savings). Fits on a single MI300X.

# rocm/vllm-dev:base tracks the current ROCm release vLLM dev image. For
# reproducible builds, pin a dated nightly_main_YYYYMMDD or vllm-v* tag
# from https://hub.docker.com/r/rocm/vllm-dev/tags via --build-arg ROCM_TAG.
ARG ROCM_TAG=base
FROM rocm/vllm-dev:${ROCM_TAG}

LABEL org.opencontainers.image.source="https://github.com/TheTom/tqkit"
LABEL org.opencontainers.image.description="vLLM + TurboQuant+ KV-cache compression for AMD ROCm"
LABEL org.opencontainers.image.licenses="Apache-2.0"

ARG VLLM_REPO=https://github.com/TheTom/vllm.git
ARG VLLM_BRANCH=feature/turboquant-amd-noautotune
ARG VLLM_COMMIT=HEAD

WORKDIR /workspace

# vLLM's setup.py auto-detects CUDA via nvcc, which fails inside a ROCm-only
# container. VLLM_TARGET_DEVICE=rocm short-circuits that detection. The base
# image already has a working vllm install; --no-build-isolation lets pip
# reuse the existing torch + ROCm wheels instead of rebuilding the world.
ENV VLLM_TARGET_DEVICE=rocm

# Pull the patched vLLM and install in editable mode so the user can
# inspect / patch from inside the container if they want to.
RUN git clone --branch ${VLLM_BRANCH} --depth 1 ${VLLM_REPO} vllm \
 && cd vllm \
 && git rev-parse HEAD > /workspace/.vllm-commit \
 && python3 use_existing_torch.py \
 && VLLM_TARGET_DEVICE=rocm pip install --no-cache-dir --no-build-isolation -e . \
 && pip install --no-cache-dir --upgrade tqkit

# Sanity: print the KV reporter info at container start so users see the
# config without running anything.
COPY entrypoint.sh /usr/local/bin/tqkit-entrypoint
RUN chmod +x /usr/local/bin/tqkit-entrypoint

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/tqkit-entrypoint"]
CMD ["--help"]
